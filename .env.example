# CodeArena — production environment for docker-compose.prod.yml
#
#   cp .env.example .env   then fill in real values   (NEVER commit .env)
#
# Generate strong secrets:
#   JWT_SECRET:        openssl rand -base64 48
#   *_PASSWORD / KEYS: openssl rand -base64 24

# --- Public site ---
# Domain that points (DNS A record) at this VPS. Caddy gets a Let's Encrypt cert for it.
DOMAIN=codearena.example.com
# Email Let's Encrypt uses for expiry notices.
ACME_EMAIL=you@example.com

# --- PostgreSQL ---
POSTGRES_DB=codearena
POSTGRES_USER=codearena
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# --- RabbitMQ ---
RABBITMQ_USER=codearena
RABBITMQ_PASSWORD=CHANGE_ME_strong_rabbit_password

# --- MinIO (S3) ---
MINIO_ROOT_USER=codearena
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password
MINIO_BUCKET=codearena-testcases

# --- JWT ---
# MUST be a long random string. A leaked secret lets anyone forge admin tokens.
JWT_SECRET=CHANGE_ME_run_openssl_rand_base64_48
JWT_ACCESS_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_MS=604800000
